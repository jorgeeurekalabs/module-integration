<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="activecampaign_product_sync" resource="default" engine="innodb" comment="ActiveCampaign Product Sync Flags">
        <column xsi:type="int" name="product_id" nullable="false" unsigned="true" comment="Product ID"/>
        <column xsi:type="int" name="store_id" nullable="false" unsigned="true" comment="Store ID"/>
        <column xsi:type="int" name="sync_status" nullable="false" default="0" comment="Sync Status"/>
        <column xsi:type="varchar" name="ac_product_id" nullable="true" length="255" comment="ActiveCampaign Product ID"/>
        <column xsi:type="timestamp" name="updated_at" nullable="true" on_update="true" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="product_id"/>
            <column name="store_id"/>
        </constraint>
        <index referenceId="ACTIVE_CAMPAIGN_PRODUCT_SYNC_STATUS_IDX">
            <column name="store_id"/>
            <column name="sync_status"/>
        </index>
    </table>
</schema>
